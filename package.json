    "dev": "tsx watch src/app.ts",
    "build": "tsc --pretty false",
    "test": "vitest run",
    "prerender": "tsx scripts/prerender.ts",
    "demo": "tsx scripts/run_demo.ts",
    "smoke": "tsx scripts/smoke_check.ts",
    "verify": "npm run build && npm run test && npm run demo && npm run smoke && npm run prerender",
    "render:assets": "powershell -ExecutionPolicy Bypass -File .\\scripts\\render_readme_assets.ps1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizcausevic-dev/pipeline-velocity-dash.git"
  },
  "license": "AGPL-3.0-or-later",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/mizcausevic-dev/pipeline-velocity-dash/issues"
  },
  "homepage": "http://velocity.kineticgain.com/",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.0",
    "@emnapi/runtime": "^1.11.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
